# Base URL of the radar-backend API.
# Local dev: http://localhost:3000   Production: https://radar-api.onrender.com
VITE_API_URL=http://localhost:3000

# MediaStack API key for news data
# Get your key at https://mediastack.com
VITE_MEDIASTACK_API_KEY=your_mediastack_api_key_here

# Claude API key for AI transcription
# Get your key at https://console.anthropic.com
VITE_CLAUDE_API_KEY=your_claude_api_key_here
